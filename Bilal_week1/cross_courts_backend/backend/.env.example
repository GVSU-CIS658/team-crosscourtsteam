PORT=5000
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=crosscourts

JWT_SECRET=replace-with-a-strong-random-secret

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-app-password

# Firebase migration (optional)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
# Relative paths are resolved from backend/
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Optional prefix to avoid writing into production collections
FIREBASE_COLLECTION_PREFIX=dev_

# Feature flags
USE_FIREBASE_ARENA_READS=false
USE_FIREBASE_BOOKING_READS=false
USE_FIREBASE_AUTH=false
USE_FIREBASE_COURTS=false
USE_FIREBASE_OPERATIONS=false
USE_FIREBASE_ONLY=false
